import javax.swing.*;

public class FactorialShort {
    public static void main(String[] args) {

        JFrame f = new JFrame("Factorial");

        JTextField in = new JTextField(5);   // input field
        JTextField out = new JTextField(10); // output field
        JButton b = new JButton("Compute");

        out.setEditable(false); // output cannot be edited

        b.addActionListener(e -> {
            try {
                int n = Integer.parseInt(in.getText());
                int fact = 1;
                for (int i = 2; i <= n; i++)
                    fact *= i;
                out.setText("" + fact);
            } catch (Exception ex) {
                out.setText("Invalid");
            }
        });

        f.setLayout(new java.awt.FlowLayout());
        f.add(in);
        f.add(b);
        f.add(out);

        f.setSize(250, 100);
        f.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        f.setVisible(true);
    }
}
